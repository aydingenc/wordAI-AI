# Safe local default. The mock provider performs no network request and costs nothing.
TRANSLATION_PROVIDER=mock
TRANSLATION_LIVE_ENABLED=false

# Required only when production is intentionally switched to Google.
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=global

# Optional browser CORS origin. Native clients do not send an Origin header.
APP_ALLOWED_ORIGIN=
